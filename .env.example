# SAP BTP Configuration
SAP_BTP_HOST=https://your-subdomain.cfapps.region.hana.ondemand.com
SAP_CLIENT_ID=your_client_id
SAP_CLIENT_SECRET=your_client_secret
SAP_TOKEN_URL=https://your-subdomain.authentication.region.hana.ondemand.com/oauth/token
SAP_MOCK_MODE=true  # Set false when you have real SAP access

# AWS Configuration
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=ap-south-1
AWS_ECR_REGISTRY=123456789.dkr.ecr.ap-south-1.amazonaws.com
SNS_ALERT_TOPIC_ARN=arn:aws:sns:ap-south-1:123456789:sapflow-alerts

# GitHub Integration
GITHUB_TOKEN=ghp_your_token_here
GITHUB_REPO=Rajiv6165/sapflow
GITHUB_WEBHOOK_SECRET=sapflow-webhook-secret-dev
PIPELINE_SYNC_INTERVAL=60

# Webhook (for local dev use ngrok URL, for prod use deployed URL)
SAPFLOW_WEBHOOK_URL=http://localhost:8000

# Database
DATABASE_URL=postgresql://sapflow:password@postgres:5432/sapflow
REDIS_URL=redis://redis:6379

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/pipeline
