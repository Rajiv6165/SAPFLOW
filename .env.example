# ============================================
# SAP BTP Real API Credentials
# ============================================
# Leave these blank to run in mock mode (fully functional, no SAP account needed)
# 
# To get real credentials:
# 1. Sign up at https://www.sap.com/products/technology-platform/trial.html
# 2. In BTP Cockpit, go to your Subaccount > Instances and Subscriptions
# 3. Create a service instance for "Authorization & Trust Management" (xsuaa)
# 4. Open the instance > Service Keys > Create
# 5. Copy clientid, clientsecret, and url (token endpoint) from the JSON
#
SAP_BTP_CLIENT_ID=
SAP_BTP_CLIENT_SECRET=
SAP_BTP_TOKEN_URL=
SAP_BTP_API_BASE_URL=

# AWS Configuration
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=ap-south-1
AWS_ECR_REGISTRY=123456789.dkr.ecr.ap-south-1.amazonaws.com
SNS_ALERT_TOPIC_ARN=arn:aws:sns:ap-south-1:123456789:sapflow-alerts

# GitHub Integration
GITHUB_TOKEN=ghp_your_token_here
GITHUB_REPO=Rajiv6165/sapflow
GITHUB_WEBHOOK_SECRET=sapflow-webhook-secret-dev
PIPELINE_SYNC_INTERVAL=60

# Webhook (for local dev use ngrok URL, for prod use deployed URL)
SAPFLOW_WEBHOOK_URL=http://localhost:8000

# Database
DATABASE_URL=postgresql://sapflow:password@postgres:5432/sapflow
REDIS_URL=redis://redis:6379

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/pipeline
